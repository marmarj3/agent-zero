# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/
**/node_modules/

#Ignore IDE files
.cursor/
.windsurf/

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/

# obsolete folders
/memory/
/knowledge/custom/
/instruments/

# Handle logs directory
logs/**
!logs/**/

# Handle tmp and usr directory
tmp/**
!tmp/**/

# hack to keep .gitkeep but ignore nested repos
# Ignore nested git repos in usr
/usr/**/.git
# Ignore specific usr subdirectories (runtime/user data)
usr/.litellm_copilot/**
usr/api/**
usr/chats/**
usr/downloads/**
usr/knowledge/**
usr/memory/**
usr/plugins/**
usr/projects/**
usr/scheduler/**
usr/workdir/**
!usr/workdir/github-copilot-agents/
!usr/workdir/github-copilot-agents/**
# But keep .gitkeep files
!usr/**/.gitkeep


# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

.agent/**
.claude/**

# Copilot customization folder (local only, not for the repo)
.github/

# Copilot processing log (local only)
Copilot-Processing.md

# Local override files
*.local
